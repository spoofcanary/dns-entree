{
  "providerId": "test.example",
  "providerName": "Test Provider",
  "serviceId": "multi",
  "serviceName": "Multi Record",
  "version": 1,
  "logoUrl": "https://test.example/logo.png",
  "description": "TXT, CNAME, and A records",
  "variableDescription": "target, ip",
  "syncPubKeyDomain": "test.example",
  "syncRedirectDomain": "test.example",
  "records": [
    {
      "type": "TXT",
      "host": "@",
      "data": "v=spf1 include:%target% ~all",
      "ttl": 3600,
      "essential": "OnApply"
    },
    {
      "type": "CNAME",
      "host": "www",
      "pointsTo": "%target%",
      "ttl": 3600,
      "essential": "OnApply"
    },
    {
      "type": "A",
      "host": "ipv4",
      "pointsTo": "%ip%",
      "ttl": 3600,
      "essential": "OnApply"
    }
  ]
}
